{
  "name": "heycode-cli",
  "version": "1.0.3",
  "module": "src/index.tsx",
  "type": "module",
  "private": false,
  "bin": {
    "heycode": "dist/index.js"
  },
  "scripts": {
    "dev": "bun run --watch src/index.tsx",
    "build": "bun build src/index.tsx --outfile dist/index.js --target bun --minify --external @opentui/core --external @opentui/react --external react --external react-router --external @ai-sdk/react && bun -e \"import fs from 'fs'; fs.cpSync('../database/drizzle', 'dist/drizzle', { recursive: true })\""
  },
  "devDependencies": {
    "@heycode/server": "workspace:*",
    "@heycode/shared": "workspace:*",
    "@types/bun": "latest",
    "@types/react": "^19.2.17"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.206",
    "@opentui/core": "^0.3.2",
    "@opentui/react": "^0.3.2",
    "ai": "^6.0.204",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "exa-js": "^2.14.0",
    "hono": "^4.12.25",
    "open": "^11.0.0",
    "opentui-spinner": "^0.0.6",
    "pretty-ms": "^9.3.0",
    "react": "^19.2.6",
    "react-router": "^7.17.0",
    "zod": "^4.4.3"
  }
}